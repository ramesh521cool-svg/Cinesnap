# ─────────────────────────────────────────────────────────────
# CineSnap Backend — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git. NEVER share keys in chat.
# ─────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────

# Anthropic Claude (AI agents)
# Get yours: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# TMDb — movie/TV metadata, posters
# Get yours (free): https://www.themoviedb.org/settings/api
TMDB_API_KEY=YOUR_TMDB_KEY_HERE

# OMDB — IMDb + Rotten Tomatoes + Metacritic ratings
# Get yours: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=YOUR_OMDB_KEY_HERE

# Google Cloud Vision API — OCR + logo + label detection
# https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=YOUR_GOOGLE_VISION_KEY_HERE

# ── Optional ──────────────────────────────────────────────────

# SerpAPI — Letterboxd + Reddit sentiment (100 free/month)
# https://serpapi.com/manage-api-key
SERPAPI_KEY=YOUR_SERPAPI_KEY_HERE

# ── Server ────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
